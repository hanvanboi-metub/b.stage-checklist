# Supabase Environment Variables
# Copy file này thành .env.local và điền giá trị thực tế

# Lấy từ: Supabase Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Lấy từ: Supabase Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Ví dụ:
# NEXT_PUBLIC_SUPABASE_URL=https://abc123def.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSI...
